{
  "app": {
    "name": "toolkit",
    "version": "4.0.0",
    "description": "Web-Based System Toolkit"
  },
  "server": {
    "port": 6969,
    "host": "0.0.0.0",
    "ssl": false,
    "maxHttpBufferSize": 100000000,
    "pingTimeout": 60000,
    "cors": { "origin": "*" }
  },
  "rateLimit": {
    "windowMs": 900000,
    "max": 5000
  },
  "logging": {
    "level": "info",
    "console": true,
    "directory": "logs",
    "maxSize": 10485760,
    "maxFiles": 10
  },
  "temp": {
    "directory": "temp_ctf",
    "autoClean": true
  },
  "taskQueue": {
    "concurrency": 3,
    "defaultTimeout": 300000
  },
  "updater": {
    "sources": ["github"],
    "githubOwner": "tosoaja",
    "githubRepo": "auto-backup",
    "backupDirectory": ".backup"
  }
}
