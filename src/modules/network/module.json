{"name":"network","version":"1.0.0","description":"Network diagnostic tools - ping, traceroute, nslookup, netstat, whois, curl","permissions":["network.ping","network.dns","network.scan"],"commands":[{"name":"ping","handler":"commands/ping.js","async":true,"timeout":60000,"permission":"network.ping","input":"text","description":"Ping a host (4 packets)"},{"name":"traceroute","handler":"commands/traceroute.js","async":true,"timeout":60000,"permission":"network.ping","input":"text","description":"Traceroute to host"},{"name":"nslookup","handler":"commands/nslookup.js","async":true,"timeout":30000,"permission":"network.dns","input":"text","description":"DNS lookup for domain"},{"name":"netstat","handler":"commands/netstat.js","async":true,"timeout":30000,"permission":"network.scan","input":"none","description":"Show listening ports and connections"},{"name":"whois","handler":"commands/whois.js","async":true,"timeout":30000,"permission":"network.dns","input":"text","description":"WHOIS lookup for domain/IP"},{"name":"curl","handler":"commands/curl.js","async":true,"timeout":30000,"permission":"network.ping","input":"text","description":"HTTP HEAD request to URL"}]}