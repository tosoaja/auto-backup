{"name":"pwn","version":"1.0.0","description":"Binary exploitation tools - pattern gen, offset, ELF info, ROP gadgets, shellcode, checksec","permissions":["pwn.read"],"commands":[{"name":"pattern","handler":"commands/pattern.js","async":false,"permission":"pwn.read","input":"text","description":"Generate cyclic pattern. Usage: pattern [length]"},{"name":"offset","handler":"commands/offset.js","async":false,"permission":"pwn.read","input":"text","description":"Find offset in cyclic pattern. Usage: offset <value>"},{"name":"elf","handler":"commands/elf.js","async":true,"timeout":15000,"permission":"pwn.read","input":"file","description":"Analyze ELF binary (architecture, sections, security)"},{"name":"rop","handler":"commands/rop.js","async":true,"timeout":60000,"permission":"pwn.read","input":"file","description":"Find ROP gadgets (requires ROPgadget)"},{"name":"shellcode","handler":"commands/shellcode.js","async":false,"permission":"pwn.read","input":"text","description":"Get shellcode by type. Types: linux-x86-exec, linux-x64-exec"},{"name":"template","handler":"commands/template.js","async":false,"permission":"pwn.read","input":"file","description":"Generate pwntools Python exploit template"},{"name":"checksec","handler":"commands/checksec.js","async":true,"timeout":15000,"permission":"pwn.read","input":"file","description":"Check binary security mitigations"},{"name":"asm","handler":"commands/asm.js","async":true,"timeout":15000,"permission":"pwn.read","input":"text","description":"Assemble instructions (Intel syntax). Usage: asm <instructions>"}]}